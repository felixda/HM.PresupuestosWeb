
@using HM.Presupuestos.Web.Adaptadores

@inherits Context

@inject IAvisosService AvisosService

@implements IDisposable

@if (_mostrarModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block text-center" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg">
                <div class="modal-header @($"bg-{_tipoClase}")">
                    <h5 class="modal-title">@IconoAviso @PageTitle</h5>
                </div>
                <div class="modal-body">
                    <p>@_mensaje</p>
                    <button class="btn @($"btn-{_tipoClase}")" @onclick="Cerrar">@TextoCerrar</button>
                </div>
            </div>
        </div>
    </div>


}

@code {

    private bool _mostrarModal = false;
    private string _mensaje = string.Empty;
    private string _tipoClase { get; set; } = "warning"; // warning, info, success, error

    private string TextoCerrar => ObtenerTexto(TextosApp.Botones.Cerrar);
    private string PageTitle => ObtenerTexto(TextosApp.Pages.Avisos.Titulo);

    protected override void OnInitialized()
    {
        base.OnInitialized();
        AvisosService.OnAvisoActivado += ManejarAvisos;
    }

    private async Task ManejarAvisos(string mensaje, TiposDeAviso tipo)
    {
        _mostrarModal = true;

        _mensaje = mensaje;
        switch  ( tipo)
        {
            case TiposDeAviso.Warning:
                {
                    _tipoClase = "warning";
                    break;
                }
            case TiposDeAviso.Info:
                {
                    _tipoClase = "info";
                    break;
                }
            case TiposDeAviso.Success:
                {
                    _tipoClase = "success";
                    break;
                }
            case TiposDeAviso.Error:
                {
                    _tipoClase = "danger";
                    break;
                }
        }

        await InvokeAsync(StateHasChanged);
    }
    

    private void Cerrar()
    {
        _mostrarModal = false;
    }

    public void Dispose()
    {
        AvisosService.OnAvisoActivado -= ManejarAvisos;
    }

    private string IconoAviso => _tipoClase switch
    {
        "warning" => "?",
        "info" => "?",
        "success" => "?",
        "danger" => "?",
        _ => "?"
    };


}

