

@inherits Context

<DxStackLayout CssClass="h-100 w-100 ch-480" Orientation="Orientation.Horizontal">
    <Items>
        <DxStackLayoutItem Length="1r">
            <Template>
                @if (UsuarioCargado)
                {
                    //Solo mostrar el bot�n de favorito si el usuario es SSO
                    @if (UsuarioImpersonado == null)
                    {
                        var claseIcono = EsFavorito ? "icon star-fill" : "icon star";
                        var tituloBoton = EsFavorito
                        ? ObtenerTexto(TextosApp.Common.DesmarcarFavorito)
                        : ObtenerTexto(TextosApp.Common.MarcarFavorito);

                        <div class="stacklayout-item">
                            <button class="btn secondary"
                            title="@tituloBoton"
                            @onclick="OnFavorito">
                                <i id="iconFavorite" class="@claseIcono"></i>
                            </button>
                        </div>
                    }
                }
            </Template>
        </DxStackLayoutItem>

        <DxStackLayoutItem Length="11fr">
            <Template>
                @if (UsuarioCargado)
                {
                    <div class="stacklayout-item">
                        <h2>@Titulo</h2>
                    </div>
                }
            </Template>
        </DxStackLayoutItem>

        @* Bot�n temporal solo para usuario Felix.Davilla-ext *@
        @if (UsuarioCargado && Usuario!.CodigoUsuario == 2825)
        {
            <DxStackLayoutItem>
                <Template>
                    <div class="stacklayout-item">
                        <button class="btn secondary"
                                title="Volver"
                                @onclick="OnVolver">
                            <i id="iconVolver" class="fas fa-reply"></i>
                        </button>
                    </div>
                </Template>
            </DxStackLayoutItem>
        }

        <DxStackLayoutItem>
            <Template>
                @if (UsuarioCargado)
                {
                    <div class="stacklayout-item">
                        <button class="btn secondary" title="@TextoToolTipAyuda">
                            <i id="iconInfo" class="icon info"></i>
                        </button>
                    </div>
                }
            </Template>
        </DxStackLayoutItem>
    </Items>
</DxStackLayout>



