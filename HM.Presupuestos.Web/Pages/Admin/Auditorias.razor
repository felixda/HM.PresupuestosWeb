@page "/admin/auditorias"

@using HM.Presupuestos.Domain.Entidades.LogAcciones

@inherits ContextProtegido

@attribute [Authorize]

@if (!UsuarioCargado || ValidandoPermisos || TienePermiso == null)
{
    @* Estado: Cargando usuario o validando permisos *@
}
else if (TienePermiso == false)
{
    <AccesoDenegado Titulo="@TituloPagina" />
}
else
{
    <PageTitle>@TituloPagina</PageTitle>
    <PageHeader CodigoMenu="@CodigosMenu.Auditorias"
                Titulo="@TituloPagina"
                TextoToolTipAyuda="@ObtenerTexto(TextosApp.Pages.Auditorias.ToolTip)" />

    <div class="layoutContainer">

        @* FILTROS *@
        <DxFormLayout>
            <DxFormLayoutGroup CssClass="filterContainer"
                               Caption="@ObtenerTexto(TextosApp.Common.Filtros)"
                               ExpandButtonDisplayMode="GroupExpandButtonDisplayMode.Start"
                               AnimationType="LayoutAnimationType.Slide">
                <Items>
                    <DxFormLayoutItem ColSpanSm="12" ColSpanMd="6" ColSpanLg="3" ColSpanXl="3" ColSpanXxl="3"
                                      CaptionPosition="CaptionPosition.Vertical" BeginRow="true">
                        <CaptionTemplate>
                            <span>@ObtenerTexto(TextosApp.Pages.Auditorias.TipoAuditoria)</span><span class="mandatory"></span>
                        </CaptionTemplate>
                        <Template>
                            <DxComboBox Data="@TiposAuditoria"
                                        TextFieldName="@nameof(CodigoDescripcion.Descripcion)"
                                        ValueFieldName="@nameof(CodigoDescripcion.Codigo)"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        SearchMode="@ListSearchMode.AutoSearch"
                                        SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                        ListRenderMode="ListRenderMode.Entire"
                                        Value="@TipoAuditoriaSeleccionado"
                                        ValueChanged="@((int? v) => { TipoAuditoriaSeleccionado = v; ResultadoAuditorias = []; _estadisticas = null; if (v != (int)AccionesLog.AccesoAPagina) PaginaSeleccionada = null; })">
                                <EditBoxDisplayTemplate Context="contexto">
                                    @ListasTemplateHelper.GetComboBoxEditBoxTemplate(contexto.DataItem)
                                </EditBoxDisplayTemplate>
                            </DxComboBox>
                        </Template>
                    </DxFormLayoutItem>

                    @if (TipoAuditoriaSeleccionado == (int)AccionesLog.AccesoAPagina)
                    {
                        <DxFormLayoutItem ColSpanSm="12" ColSpanMd="6" ColSpanLg="3" ColSpanXl="3" ColSpanXxl="3"
                                          Caption="@ObtenerTexto(TextosApp.Pages.Auditorias.Pagina)"
                                          CaptionPosition="CaptionPosition.Vertical">
                            <Template>
                                <DxComboBox Data="@PaginasNavegables"
                                            TextFieldName="@nameof(CodigoDescripcion.Descripcion)"
                                            ValueFieldName="@nameof(CodigoDescripcion.Codigo)"
                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                            SearchMode="@ListSearchMode.AutoSearch"
                                            SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                            ListRenderMode="ListRenderMode.Entire"
                                            NullText="@ObtenerTexto(TextosApp.Common.Todos)"
                                            @bind-Value="@PaginaSeleccionada">
                                    <EditBoxDisplayTemplate Context="contexto">
                                        @ListasTemplateHelper.GetComboBoxEditBoxTemplate(contexto.DataItem)
                                    </EditBoxDisplayTemplate>
                                </DxComboBox>
                            </Template>
                        </DxFormLayoutItem>
                    }

                    <DxFormLayoutItem ColSpanSm="12" ColSpanMd="4" ColSpanLg="2" ColSpanXl="2" ColSpanXxl="2"
                                      CaptionPosition="CaptionPosition.Vertical">
                        <CaptionTemplate>
                            <span>@ObtenerTexto(TextosApp.Pages.Auditorias.FechaInicio)</span><span class="mandatory"></span>
                        </CaptionTemplate>
                        <Template>
                            <DxDateEdit @bind-Date="@FechaInicio"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        NullText="@ObtenerTexto(TextosApp.Common.Todos)" />
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanSm="12" ColSpanMd="4" ColSpanLg="2" ColSpanXl="2" ColSpanXxl="2"
                                      CaptionPosition="CaptionPosition.Vertical">
                        <CaptionTemplate>
                            <span>@ObtenerTexto(TextosApp.Pages.Auditorias.FechaFin)</span><span class="mandatory"></span>
                        </CaptionTemplate>
                        <Template>
                            <DxDateEdit @bind-Date="@FechaFin"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        NullText="@ObtenerTexto(TextosApp.Common.Todos)" />
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanSm="12" ColSpanMd="12" ColSpanLg="12" ColSpanXl="12" ColSpanXxl="12"
                                      BeginRow="true">
                        <div class="d-flex justify-content-between">
                            <DxButton CssClass="btnCustom"
                                      RenderStyle="ButtonRenderStyle.None"
                                      IconCssClass="fa-solid fa-magnifying-glass"
                                      Text="@ObtenerTexto(TextosApp.Common.Buscar)"
                                      Click="BuscarAuditoriasAsync" />
                            <DxButton CssClass="btnCustom"
                                      RenderStyle="ButtonRenderStyle.None"
                                      IconCssClass="fa-solid fa-eraser"
                                      Text="@ObtenerTexto(TextosApp.Common.Limpiar)"
                                      Click="LimpiarFiltroAsync" />
                        </div>
                    </DxFormLayoutItem>
                </Items>
            </DxFormLayoutGroup>
        </DxFormLayout>

        @* ESTADÍSTICAS *@
        @if (_estadisticas != null)
        {
            <DxFormLayout>
                <DxFormLayoutGroup Caption="@ObtenerTexto(TextosApp.Pages.Auditorias.ResumenPeriodo)"
                                   CssClass="filterContainer stats-panel"
                                   ExpandButtonDisplayMode="GroupExpandButtonDisplayMode.Start"
                                   AnimationType="LayoutAnimationType.Slide">
                    <Items>
                        <DxFormLayoutItem ColSpanSm="12" ColSpanMd="12" ColSpanLg="12" ColSpanXl="12" ColSpanXxl="12">
                            <div class="stats-cards">
                                <div class="stat-card">
                                    <span class="stat-value">@_estadisticas.TotalAcciones</span>
                                    <span class="stat-label">@ObtenerTexto(TextosApp.Pages.Auditorias.TotalAcciones)</span>
                                </div>
                                <div class="stat-card">
                                    <span class="stat-value">@_estadisticas.UsuariosUnicos</span>
                                    <span class="stat-label">@ObtenerTexto(TextosApp.Pages.Auditorias.UsuariosUnicos)</span>
                                </div>
                                <div class="stat-card">
                                    <span class="stat-value">@_estadisticas.UsuarioMasActivo</span>
                                    <span class="stat-sublabel">(@_estadisticas.UsuarioMasActivoTotal)</span>
                                    <span class="stat-label">@ObtenerTexto(TextosApp.Pages.Auditorias.UsuarioMasActivo)</span>
                                </div>
                                @if (TipoAuditoriaSeleccionado == (int)AccionesLog.AccesoAPagina && !string.IsNullOrEmpty(_estadisticas.PaginaMasVisitada))
                                {
                                    <div class="stat-card">
                                        <span class="stat-value stat-value--small">@_estadisticas.PaginaMasVisitada</span>
                                        <span class="stat-sublabel">(@_estadisticas.PaginaMasVisitadaTotal)</span>
                                        <span class="stat-label">@ObtenerTexto(TextosApp.Pages.Auditorias.PaginaMasVisitada)</span>
                                    </div>
                                }
                            </div>
                        </DxFormLayoutItem>

                        @if (_estadisticas.TopUsuarios.Count > 0)
                        {
                            <DxFormLayoutItem ColSpanSm="12" ColSpanMd="6" ColSpanLg="4" ColSpanXl="4" ColSpanXxl="4">
                                <div class="stats-section">
                                    <span class="stats-section-title">@ObtenerTexto(TextosApp.Pages.Auditorias.TopUsuarios)</span>
                                    @foreach (var usuario in _estadisticas.TopUsuarios)
                                    {
                                        <div class="top-usuario-row">
                                            <span class="top-usuario-login">@usuario.Login</span>
                                            <DxProgressBar Value="@usuario.Total"
                                                           MaxValue="@_estadisticas.TopUsuarios[0].Total"
                                                           ShowLabel="false"
                                                           CssClass="top-usuario-bar" />
                                            <span class="top-usuario-total">@usuario.Total</span>
                                        </div>
                                    }
                                </div>
                            </DxFormLayoutItem>
                        }

                        <DxFormLayoutItem ColSpanSm="12" ColSpanMd="6" ColSpanLg="8" ColSpanXl="8" ColSpanXxl="8">
                            <div class="stats-section">
                                <span class="stats-section-title">@ObtenerTexto(TextosApp.Pages.Auditorias.ActividadDiaria)</span>
                                @if (RangoSuperaLimite)
                                {
                                    <span class="stats-rango-aviso">@ObtenerTexto(TextosApp.Pages.Auditorias.RangoDemasiadoAmplio)</span>
                                }
                                else if (_estadisticas.ActividadPorDia.Count > 0)
                                {
                                    <DxChart Data="@_estadisticas.ActividadPorDia"
                                             CssClass="stats-chart">
                                        <DxChartBarSeries T="PuntoTemporal"
                                                          TValue="int"
                                                          TArgument="DateTime"
                                                          ValueField="@(p => p.Total)"
                                                          ArgumentField="@(p => p.Fecha)"
                                                          Name="@ObtenerTexto(TextosApp.Pages.Auditorias.TotalAcciones)" />
                                        <DxChartArgumentAxis>
                                            <DxChartAxisLabel Format="@ChartElementFormat.MonthAndDay" />
                                        </DxChartArgumentAxis>
                                        <DxChartValueAxis>
                                            <DxChartAxisLabel Format="@ChartElementFormat.Decimal()" />
                                        </DxChartValueAxis>
                                        <DxChartLegend Visible="false" />
                                        <DxChartTooltip Enabled="true" Context="tooltipCtx">
                                            @{
                                                var point = tooltipCtx.GetCommonPoint<PuntoTemporal, int>(p => p.Total);
                                            }
                                            <div style="padding:4px 8px">
                                                <b>@((DateTime)point.Argument).ToString("dd/MM/yyyy")</b>: @point.Value
                                            </div>
                                        </DxChartTooltip>
                                    </DxChart>
                                }
                            </div>
                        </DxFormLayoutItem>
                    </Items>
                </DxFormLayoutGroup>
            </DxFormLayout>
        }

        @* RESULTADOS *@
        <DxGrid Data="@ResultadoAuditorias"
                PageSize="20"
                ColumnResizeMode="GridColumnResizeMode.NextColumn"
                TextWrapEnabled="false"
                HighlightRowOnHover="true">
            <Columns>
                <DxGridDataColumn FieldName="@nameof(Auditoria.Descripcion)"
                                  Caption="@ObtenerTexto(TextosApp.Common.Descripcion)"
                                  Width="50%"
                                  CaptionAlignment="GridTextAlignment.Left"
                                  TextAlignment="GridTextAlignment.Left" />
                <DxGridDataColumn FieldName="@nameof(Auditoria.FechaInicio)"
                                  Caption="@ObtenerTexto(TextosApp.Pages.Auditorias.FechaInicio)"
                                  Width="20%"
                                  DisplayFormat="dd/MM/yyyy HH:mm:ss"
                                  CaptionAlignment="GridTextAlignment.Left"
                                  TextAlignment="GridTextAlignment.Left" />
                <DxGridDataColumn FieldName="@nameof(Auditoria.Usuario)"
                                  Caption="@ObtenerTexto(TextosApp.Pages.Auditorias.Usuario)"
                                  Width="25%"
                                  CaptionAlignment="GridTextAlignment.Left"
                                  TextAlignment="GridTextAlignment.Left" />
                <DxGridDataColumn FieldName="@nameof(Auditoria.Parametros)"
                                  Caption="@ObtenerTexto(TextosApp.Pages.Auditorias.Parametros)"
                                  Width="5%"
                                  CaptionAlignment="GridTextAlignment.Center"
                                  TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate>
                        @{
                            var auditoria = (Auditoria)context.DataItem;
                        }
                        <button class="btn-parametros" title="@ObtenerTexto(TextosApp.Pages.Auditorias.TituloPopupParametros)"
                                @onclick="() => AbrirPopupParametros(auditoria)">
                            <i class="fa-solid fa-file-code"></i>
                        </button>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
        </DxGrid>

        <DxPopup Visible="@_popupParametrosVisible"
                 VisibleChanged="@((bool v) => _popupParametrosVisible = v)"
                 HeaderText="@ObtenerTexto(TextosApp.Pages.Auditorias.TituloPopupParametros)"
                 Width="700px"
                 CloseOnOutsideClick="true">
            <BodyContentTemplate>
                <pre class="parametros-pre">@_auditoriaSeleccionada?.Parametros</pre>
            </BodyContentTemplate>
        </DxPopup>

    </div>
}
