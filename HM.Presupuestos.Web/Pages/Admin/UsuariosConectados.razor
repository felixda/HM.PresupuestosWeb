@page "/admin/usuarios-conectados"

@inherits ContextProtegido

@attribute [Authorize]

@if (!UsuarioCargado || ValidandoPermisos || TienePermiso == null)
{
    @* Estado: Cargando usuario o validando permisos *@
}
else if (TienePermiso == false)
{
    <AccesoDenegado Titulo="@TituloPagina" />
}
else
{
    <PageTitle>@TituloPagina</PageTitle>
    <PageHeader CodigoMenu="@CodigosMenu.UsuariosConectados"
                Titulo="@TituloPagina" />

    <div class="layoutContainer">

        <div class="usuarios-conectados-toolbar">
            <DxButton Text="@ObtenerTexto(TextosApp.Pages.UsuariosConectados.Actualizar)"
                      IconCssClass="fa-solid fa-rotate-right"
                      Click="@ActualizarAsync"
                      RenderStyle="ButtonRenderStyle.Secondary" />
        </div>

        @if (_sesiones.Count == 0)
        {
            <div class="usuarios-conectados-empty">
                <span>@ObtenerTexto(TextosApp.Pages.UsuariosConectados.SinUsuariosConectados)</span>
            </div>
        }
        else
        {
            <DxGrid Data="@_sesiones"
                    ShowFilterRow="false"
                    PageSize="50"
                    SelectedDataItemChanged="@OnUsuarioSeleccionadoAsync">
                <Columns>
                    <DxGridDataColumn FieldName="@nameof(SesionActivaInfo.Login)"
                                      Caption="@ObtenerTexto(TextosApp.Pages.UsuariosConectados.Login)"
                                      MinWidth="150" />
                    <DxGridDataColumn FieldName="@nameof(SesionActivaInfo.PaginaActual)"
                                      Caption="@ObtenerTexto(TextosApp.Pages.UsuariosConectados.PaginaActual)"
                                      MinWidth="200" />
                    <DxGridDataColumn FieldName="@nameof(SesionActivaInfo.Inicio)"
                                      Caption="@ObtenerTexto(TextosApp.Pages.UsuariosConectados.ConectadoDesde)"
                                      DisplayFormat="HH:mm:ss"
                                      MinWidth="130" />
                    <DxGridDataColumn Caption="@ObtenerTexto(TextosApp.Pages.UsuariosConectados.TiempoEnSesion)"
                                      MinWidth="130">
                        <CellDisplayTemplate Context="ctx">
                            @FormatearTiempo((SesionActivaInfo)ctx.DataItem)
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                </Columns>
            </DxGrid>

            @if (_usuarioSeleccionado != null)
            {
                <div class="usuarios-conectados-historial">
                    <h4>@ObtenerTexto(TextosApp.Pages.HistorialNavegacion.Titulo) — @_usuarioSeleccionado.Login</h4>

                    @if (_historialUsuario.Count == 0)
                    {
                        <div class="usuarios-conectados-empty">
                            <span>@ObtenerTexto(TextosApp.Pages.HistorialNavegacion.SinHistorial)</span>
                        </div>
                    }
                    else
                    {
                        <DxGrid Data="@_historialUsuario"
                                ShowFilterRow="false"
                                PageSize="50">
                            <Columns>
                                <DxGridDataColumn FieldName="@nameof(EntradaHistorial.Pagina)"
                                                  Caption="@ObtenerTexto(TextosApp.Pages.HistorialNavegacion.PaginaVisitada)"
                                                  MinWidth="200" />
                                <DxGridDataColumn FieldName="@nameof(EntradaHistorial.Hora)"
                                                  Caption="@ObtenerTexto(TextosApp.Pages.HistorialNavegacion.Hora)"
                                                  DisplayFormat="HH:mm:ss"
                                                  MinWidth="100" />
                            </Columns>
                        </DxGrid>
                    }
                </div>
            }
        }
    </div>
}
