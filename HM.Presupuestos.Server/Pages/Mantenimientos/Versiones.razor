@page "/mantenimiento/versiones"
@using HM.Presupuestos.Server.Servicios

@using Version = HM.Presupuestos.Contratos.Entidades.Version

@inject IJwt _Jwt
@inject VersionesService _VersionesService
@inject IndicadoresService _IndicadoresService
@inject ILogService _LogService
@inject MensajesHelper _MensajesHelper
@inject TraduccionesHelper _TraduccionesHelper
@inject ErrorDialogService _ErrorService
@inject ILogAccionesService _LogAccionesService
@inject ILayerOverlayService _LayerOverlayService
@inject NavigationManager Navigation
@inject IUsuarioServicio _UsuarioService


@inherits ContextProtegido

@* @inject Context UserContext *@
@attribute [Authorize]
@attribute [StreamRendering(true)]


@if (ValidandoPermisos)
{
    @* <p>Validando permisos...</p> *@
}
else if (!TienePermiso)
{
    <p>No autorizado</p>
}

else
{
    <PageHeader CodigoMenu="@CodigosMenu.Versiones" Titulo="@_pageTitle" TextoToolTipAyuda="@T(AppResources.Pages.GestionVersiones.ToolTip)" />

    <div class="layoutContainer">
        @* FILTER *@
        <DxFormLayout>
            <DxFormLayoutGroup CssClass="filterContainer" 
            Caption="@T("common:filtros:label")" 
            ExpandButtonDisplayMode="GroupExpandButtonDisplayMode.Start" 
            AnimationType="LayoutAnimationType.Slide">
                <DxFormLayoutItem ColSpanSm="4" ColSpanMd="2" ColSpanLg="2" ColSpanXl="2" ColSpanXxl="2" 
                Caption="@($"{T("common:anio:label")}")" 
                CaptionPosition="CaptionPosition.Vertical">
                    <DxComboBox Data="@_listYear"
                    Enabled="@(JsonSerializer.Serialize(_listVersion)==JsonSerializer.Serialize(_listOriginVersion))"
                    TextFieldName=@nameof(CodigoDescripcion.Descripcion)
                    ValueFieldName=@nameof(CodigoDescripcion.Codigo)
                    SearchMode="@ListSearchMode.AutoSearch"
                    SearchFilterCondition="@ListSearchFilterCondition.Contains"
                    @bind-Value="@_itemYearSelected"
                    SelectedDataItemChanged="(SelectedDataItemChangedEventArgs<CodigoDescripcion> args) => Param_Year_SelectedDataItemChanged(args)">
                        <EditBoxDisplayTemplate Context="contexto">
                            @ListasTemplateHelper.GetComboBoxEditBoxTemplate(contexto.DataItem)
                        </EditBoxDisplayTemplate>
                    </DxComboBox>
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
        </DxFormLayout>
        @* GRID VERSIONES *@
        <DxFormLayout>
            <DxFormLayoutGroup Caption="@T("Pages:Versiones:Versiones:label")" ColSpanSm="12" ColSpanMd="12" ColSpanLg="12" ColSpanXl="12" ColSpanXxl="12">
                <DxFormLayoutItem ColSpanSm="12" ColSpanMd="12" ColSpanLg="12" ColSpanXl="12" ColSpanXxl="12" Context="formLayout">
                    <DxGrid @ref="_GridVersiones"
                    Data="_listVersion"
                    KeyFieldName="Codigo"
                    ValidationEnabled="true"
                    ShowFilterRow="true"
                    EditMode="GridEditMode.EditCell"
                    EditModelSaving="GridVersiones_EditModelSaving"
                    CustomizeElement="GridVersiones_CustomizeElement"
                    ColumnResizeMode="GridColumnResizeMode.NextColumn"
                    CustomizeDataRowEditor="GridVersiones_CustomizeDataRowEditor"
                    TextWrapEnabled="false"
                    HighlightRowOnHover="true"
                    PageSizeSelectorVisible="false">
                        <ToolbarTemplate>
                            <div class="d-flex justify-content-start">
                                <DxButton CssClass="toolbarButtonCustom"
                                RenderStyle=ButtonRenderStyle.None
                                Text="@T("common:Nuevo:label")"
                                Click="NewVersion"
                                Enabled="@(_listVersion.Find(x => x.Codigo == 0)==null)"
                                IconCssClass="fa-solid fa-plus" />
                            </div>
                            <div class="d-flex justify-content-start">
                                <DxButton CssClass="toolbarButtonCustom"
                                RenderStyle=ButtonRenderStyle.None
                                Text="@T("common:Cancelar:label")"
                                Click="CancelVersion"
                                IconCssClass="fa-solid fa-cancel"
                                Enabled="@(JsonSerializer.Serialize(_listVersion)!=JsonSerializer.Serialize(_listOriginVersion))" />
                            </div>
                        </ToolbarTemplate>
                        <Columns>
                            <DxGridDataColumn FieldName="@nameof(Version.Codigo)" 
                            FilterRowEditorVisible="false" 
                            Caption="@T("common:Codigo:label")" 
                            Width="5%" 
                            ReadOnly="true" 
                            CaptionAlignment="GridTextAlignment.Right" 
                            TextAlignment="GridTextAlignment.Right" 
                            DataRowEditorVisible="false">
                                <FilterRowCellTemplate>
                                </FilterRowCellTemplate>
                                <CellDisplayTemplate>
                                    <span class="dxgrid-readonly-cell">@context.DisplayText</span>
                                </CellDisplayTemplate>
                            </DxGridDataColumn>

                            <DxGridDataColumn FieldName="@nameof(Version.Orden)" FilterRowEditorVisible="false" Caption="@T("common:Orden:label")" Width="6%" CaptionAlignment="GridTextAlignment.Right" TextAlignment="GridTextAlignment.Right"
                            SortIndex="0" SortOrder="GridColumnSortOrder.Descending">
                                <FilterRowCellTemplate>
                                </FilterRowCellTemplate>
                            </DxGridDataColumn>

                            <DxGridDataColumn FieldName="@nameof(Version.Descripcion)" 
                            FilterRowEditorVisible="true" 
                            Caption="@T("Pages:Versiones:Version:label")" 
                            CaptionAlignment="GridTextAlignment.Left" 
                            TextAlignment="GridTextAlignment.Left" />


                            <DxGridDataColumn FieldName="@nameof(Version.Mes)" FilterRowEditorVisible="false" Caption="@T("common:Mes:label")" Width="7%" CaptionAlignment="GridTextAlignment.Left" TextAlignment="GridTextAlignment.Left">
                                <FilterRowCellTemplate>
                                </FilterRowCellTemplate>
                                <CellDisplayTemplate>
                                    @_listMonth.FirstOrDefault(option => option.Codigo == (context.Value == null ? -1 : (int)context.Value))?.Descripcion
                                </CellDisplayTemplate>
                                <CellEditTemplate>
                                    @{
                                        var version = (Version)context.EditModel;
                                    }
                                    <DxComboBox Data="@_listMonth"
                                    TextFieldName=@nameof(CodigoDescripcion.Descripcion)
                                    ValueFieldName=@nameof(CodigoDescripcion.Codigo)
                                    @bind-Value="@version.Mes" />
                                </CellEditTemplate>
                            </DxGridDataColumn>
                            <DxGridBandColumn Caption="@T("Pages:Versiones:Indicadores:label")" Width="60%" CaptionAlignment="GridTextAlignment.Center">
                                <Columns>
                                    @{
                                        @if (_listVersion.Any())
                                        {
                                            var columnIndicadorWidth = (60 / _listMasterIndicador.Count).ToString() + "%";
                                            foreach (var indicadorVersion in _listVersion.First().IndicadorList)
                                            {
                                                var itemMasterIndicador = _listMasterIndicador.FirstOrDefault(x => x.Codigo == indicadorVersion.Codigo);
                                                if (itemMasterIndicador!=null)
                                                {
                                                    <DxGridDataColumn Caption="@($"Indicador_{itemMasterIndicador.Codigo}")" ReadOnly="false" Width="@columnIndicadorWidth"
                                                    Visible="@itemMasterIndicador.IndMostrar" FilterRowEditorVisible="false"

                                                    CaptionAlignment="GridTextAlignment.Center" TextAlignment="GridTextAlignment.Center">
                                                        <FilterRowCellTemplate>
                                                        </FilterRowCellTemplate>
                                                        <HeaderCaptionTemplate>
                                                            <span title="@itemMasterIndicador.Leyenda">
                                                                @itemMasterIndicador.DescripcionAbreviada
                                                            </span>
                                                        </HeaderCaptionTemplate>
                                                        <CellDisplayTemplate>
                                                            @if (context.DataItem is Version version)
                                                            {
                                                                var item = version.IndicadorList.FirstOrDefault(x => x.Codigo == itemMasterIndicador.Codigo);
                                                                bool estadoCheck = item?.Estado ?? false;

                                                                <DxCheckBox Checked="@estadoCheck"
                                                                ReadOnly="false" ValidationEnabled="false"
                                                                CheckedChanged="@((bool? newValue) => CheckboxIndicadorCheckedChanged( newValue, version.Codigo ,indicadorVersion.Codigo))" />
                                                            }
                                                        </CellDisplayTemplate>
                                                    </DxGridDataColumn>
                                                }
                                            }
                                        }
                                    }
                                </Columns>
                            </DxGridBandColumn>

                            <DxGridDataColumn FieldName="@nameof(Version.CodigoTipo)" FilterRowEditorVisible="false" Caption="@T("Pages:Versiones:Tipo:label")" Width="8%"
                            TextAlignment="GridTextAlignment.Left" CaptionAlignment="GridTextAlignment.Left">
                                <FilterRowCellTemplate>
                                </FilterRowCellTemplate>
                                <CellDisplayTemplate>
                                    @_listTipoVersion.FirstOrDefault(option => option.Codigo == (context.Value == null ? -1 : (int)context.Value))?.Descripcion
                                </CellDisplayTemplate>
                                <CellEditTemplate>
                                    @{
                                        var version = (Version)context.EditModel;
                                        var isReadOnly = version?.IsDataLinked == true;
                                    }
                                    @if (isReadOnly)
                                    {
                                        <span>
                                            @_listTipoVersion.FirstOrDefault(option => option.Codigo == version?.CodigoTipo)?.Descripcion
                                        </span>
                                    }
                                    else
                                    {
                                        <DxComboBox Data="@_listTipoVersion"
                                        TextFieldName=@nameof(CodigoDescripcion.Descripcion)
                                        ValueFieldName=@nameof(CodigoDescripcion.Codigo)
                                        @bind-Value="@version!.CodigoTipo" />
                                    }
                                </CellEditTemplate>
                            </DxGridDataColumn>

                            <DxGridCommandColumn Width="5%" NewButtonVisible="false">
                                <FilterRowCellTemplate></FilterRowCellTemplate>
                                <CellDisplayTemplate>
                                    @{
                                        var version = (Version)context.DataItem;
                                        var isReadOnly = version?.IsDataLinked == true;
                                    }
                                    <div class="grid-cell-align-center">
                                        <DxButton IconCssClass="fas fa-trash"
                                        Disabled="@isReadOnly"
                                        RenderStyle="ButtonRenderStyle.Link"
                                        aria-label="Delete"
                                        title="@(isReadOnly
                                                                ? T("Pages:Versiones:HayDatosRelacionadosConLaVersion:label")
                                                                : T("common:EliminarRegistro:label"))"
                                        Click="@(() => DeleteVersion(context.DataItem))" />
                                    </div> 

                                </CellDisplayTemplate>
                                <CellEditTemplate>
                                    <div class="grid-cell-align-center">
                                        <DxButton Enabled="false"
                                        aria-label="Delete"
                                        CssClass="grid-disabled-button"
                                        IconCssClass="fas fa-trash"
                                        RenderStyle="ButtonRenderStyle.Link" />
                                    </div>
                                </CellEditTemplate>
                            </DxGridCommandColumn>

                        </Columns>
                    </DxGrid>
                </DxFormLayoutItem>
                <DxFormLayoutItem BeginRow="true"></DxFormLayoutItem>
                <DxFormLayoutItem ColSpanSm="4" ColSpanMd="3" ColSpanLg="2" ColSpanXl="2" ColSpanXxl="2" BeginRow="true">
                    <div class="d-flex justify-content-start">
                        <div class="d-flex justify-content-start">
                            <DxButton CssClass="toolbarButtonCustom"
                            RenderStyle=ButtonRenderStyle.None
                            Text="@T("botones:Grabar:label")"
                            Click="SaveVersionData"
                            IconCssClass="fa-solid fa-save"
                            Enabled="true" />
                        </div>
                    </div>
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
        </DxFormLayout>

        <DxFormLayout>
            <DxFormLayoutGroup Caption="@T("Pages:Versiones:LeyendasIndicadores:label")" ExpandButtonDisplayMode="GroupExpandButtonDisplayMode.Start" AnimationType="LayoutAnimationType.Slide">
                <DxFormLayoutItem ColSpanSm="12" ColSpanMd="12" ColSpanLg="12" ColSpanXl="12" ColSpanXxl="12">
                    <ChildContent Context="formLayoutContext">
                        <DxGrid @ref="_GridLeyendas" Data="_listMasterIndicador.Where(c=> c.IndMostrar)" PageSize="20"
                        CustomizeElement="GridLeyendas_CustomizeElement">
                            <Columns>
                                <DxGridDataColumn FieldName="@nameof(Indicador.Descripcion)" Caption="@T("Pages:Versiones:NombreIndicador:label")" Width="25%" CaptionAlignment="GridTextAlignment.Left" TextAlignment="GridTextAlignment.Left" />
                                <DxGridDataColumn FieldName="@nameof(Indicador.DescripcionAbreviada)" Caption="@T("common:DescripcionAbreviada:label")" Width="15%" CaptionAlignment="GridTextAlignment.Left" TextAlignment="GridTextAlignment.Left" />
                                <DxGridDataColumn FieldName="@nameof(Indicador.Leyenda)" Caption="@T("common:Descripcion:label")" CaptionAlignment="GridTextAlignment.Left" TextAlignment="GridTextAlignment.Left" />
                            </Columns>
                        </DxGrid>
                    </ChildContent>
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
        </DxFormLayout>
    </div>
}


