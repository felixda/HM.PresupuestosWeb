@page "/gestion/planificacion-condiciones"

@using HM.Presupuestos.Application.CasosDeUso
@using HM.Presupuestos.Domain.Entidades
@using HM.Core.Comun.v6.Seguridad.Interfaces
@using HM.Presupuestos.Domain.Compartido
@using HM.Presupuestos.Server.Adaptadores
@using static HM.Presupuestos.Application.CasosDeUso.VersionesService
@using HM.Presupuestos.Server.Componentes.Base
@using Version = HM.Presupuestos.Domain.Entidades.Version
@using DevExpress.Blazor

@inherits Context

@attribute [StreamRendering(true)]
@attribute [Authorize]


@if (_componentInitialized)
{
    <PageTitle>@PageTitle</PageTitle>
    <PageHeader CodigoMenu="@CodigosMenu.PlanificacionCondiciones" Titulo="@PageTitle" TextoToolTipAyuda="@TextoToolTipAyuda" />

    <div class="layoutContainer">
        @* FILTER *@

        @* FILTER HEADER *@        
        <div class="filterHeader">
            <DxFormLayout>
                <DxFormLayoutItem ColSpanSm="12" ColSpanMd="12" ColSpanLg="12" ColSpanXl="12" ColSpanXxl="12"
                                  CaptionPosition="CaptionPosition.Horizontal">
                    <div class="d-flex justify-content-end">
                       
                        <div class="dxradiogroup-container">
                            <DxRadioGroup Id="radioGroupAcuerdo"
                                          ItemLabelPosition="LabelPosition.Right"
                                          ItemAlignment="CheckBoxContentAlignment.Center"
                                          Items="@_radioGroupAcuerdoButtonList"
                                          Value="@_radioGroupAcuerdoChecked"
                                          ValueChanged="@((string val) => RadioGroupAcuerdo_ValueChanged(val))"
                                          CssClass="dxradiogroup-horizontal" />
                        </div>
                    </div>
                </DxFormLayoutItem>

            </DxFormLayout>
        </div>

        @* FILTER BODY *@    
        <DxFormLayout>
            <DxFormLayoutGroup Visible="true"
            ColSpanSm="12" ColSpanMd="12" ColSpanLg="12" ColSpanXl="12" ColSpanXxl="12"
            Caption="@ObtenerTexto(AppResources.Common.Filtros)"
            ExpandButtonDisplayMode="GroupExpandButtonDisplayMode.Start"
            AnimationType="LayoutAnimationType.Slide">
                <Items>
                    <DxFormLayoutItem ColSpanSm="12" ColSpanMd="6" ColSpanLg="2" ColSpanXl="2" ColSpanXxl="2" BeginRow="true"
                    CaptionPosition="CaptionPosition.Vertical" Context="formLayout">
                        <CaptionTemplate>
                            <span>@ObtenerTexto(AppResources.Common.Network)</span><span class="mandatory"></span>
                        </CaptionTemplate>
                        <Template>
                            <DxComboBox Data="@_networks" Enabled="true"
                                        Id="comboBoxNetWorks"
                                        TextFieldName=@nameof(CodigoDescripcion.Descripcion)
                                        ValueFieldName=@nameof(CodigoDescripcion.Codigo)
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        ListRenderMode="ListRenderMode.Virtual"
                                        SearchMode="@ListSearchMode.AutoSearch"
                                        SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                        SelectedDataItemChanged="(SelectedDataItemChangedEventArgs<CodigoDescripcion> args) => ComboBoxNetwork_SelectedDataItemChanged(args)"
                                        @bind-Value="@_networkSeleccionado">
                                <EditBoxDisplayTemplate Context="contexto">
                                    @ListasTemplateHelper.GetComboBoxEditBoxTemplate(contexto.DataItem)
                                </EditBoxDisplayTemplate>
                            </DxComboBox>
                        </Template>
                    </DxFormLayoutItem>

                  

                    <DxFormLayoutItem ColSpanSm="12" ColSpanMd="6" ColSpanLg="5" ColSpanXl="5" ColSpanXxl="5"
                                      CaptionPosition="CaptionPosition.Vertical">
                        <CaptionTemplate>
                            <span>@ObtenerTexto(AppResources.Common.GrupoClientes)</span><span class="mandatory"></span>
                        </CaptionTemplate>
                        <Template>
                            <DxComboBox Data="@_gruposClientes"
                                        @bind-Value="@_codigoGrupoSeleccionado"
                                        ValueFieldName="@nameof(CodigoDescripcion.Codigo)"
                                        TextFieldName="@nameof(CodigoDescripcion.DescripcionConCodigo)"
                                        SearchMode="@ListSearchMode.AutoSearch"
                                        SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        ListRenderMode="ListRenderMode.Virtual"
                                        >
                                <EditBoxDisplayTemplate Context="contexto">
                                    @ListasTemplateHelper.GetComboBoxEditBoxTemplate(contexto.DataItem)
                                </EditBoxDisplayTemplate>
                            </DxComboBox>
                        </Template>
                    </DxFormLayoutItem>




                    <DxFormLayoutItem ColSpanSm="12" ColSpanMd="6" ColSpanLg="2" ColSpanXl="2" ColSpanXxl="2"
                                      CaptionPosition="CaptionPosition.Vertical">
                        <CaptionTemplate>
                            <span>@ObtenerTexto(AppResources.Common.Anio)</span><span class="mandatory"></span>
                        </CaptionTemplate>
                        <Template>
                            <DxComboBox Data="@_anios" Enabled="true"
                                        TextFieldName=@nameof(CodigoDescripcion.Descripcion)
                                        ValueFieldName=@nameof(CodigoDescripcion.Codigo)
                                        @bind-Value="@_anioSeleccionado"
                                        SearchMode="@ListSearchMode.AutoSearch"
                                        SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        SelectedDataItemChanged="(SelectedDataItemChangedEventArgs<CodigoDescripcion> args) =>
                                    ComboAnios_SelectedDataItemChanged(args)" >
                                <EditBoxDisplayTemplate Context="contexto">
                                    @ListasTemplateHelper.GetComboBoxEditBoxTemplate(contexto.DataItem)
                                </EditBoxDisplayTemplate>
                            </DxComboBox>
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanSm="12" ColSpanMd="6" ColSpanLg="3" ColSpanXl="3" ColSpanXxl="3"
                    CaptionPosition="CaptionPosition.Vertical" Context="formLayout">
                        <CaptionTemplate>
                            <span>@ObtenerTexto(AppResources.Common.Version)</span><span class="mandatory"></span>
                        </CaptionTemplate>
                        <Template>
                            <DxComboBox Data="@_versiones"
                                        TextFieldName=@nameof(VersionResumen.Descripcion)
                                        ValueFieldName=@nameof(VersionResumen.Codigo)
                                        @bind-Value="_versionSeleccionada"
                                        SearchMode="@ListSearchMode.AutoSearch"
                                        SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" >
                                <ItemDisplayTemplate Context="contexto">
                                    @ListasTemplateHelper.GetComboBoxItemTemplate(contexto)
                                </ItemDisplayTemplate>

                                <EditBoxDisplayTemplate Context="contexto">
                                    @ListasTemplateHelper.GetComboBoxEditBoxTemplate(contexto.DataItem)
                                </EditBoxDisplayTemplate>

                            </DxComboBox>
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem BeginRow="true"></DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanSm="4" ColSpanMd="3" ColSpanLg="2" ColSpanXl="2" ColSpanXxl="2" BeginRow="true">
                        <div class="d-flex justify-content-start">
                            <DxButton CssClass="btnCustom"
                                      RenderStyle=ButtonRenderStyle.None
                                      Text="@ObtenerTexto(AppResources.Common.Buscar)"
                                      IconCssClass="fa-solid fa-search"
                                      Click="@FiltroBuscar" />
                        </div>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanSm="1" ColSpanMd="6" ColSpanLg="8" ColSpanXl="8" ColSpanXxl="8"> </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanSm="3" ColSpanMd="3" ColSpanLg="2" ColSpanXl="2" ColSpanXxl="2">
                        <div class="d-flex justify-content-end">
                            <DxButton CssClass="btnCustom"
                            RenderStyle=ButtonRenderStyle.None
                                      IconCssClass="fa-solid fa-trash"
                            Text="@ObtenerTexto(AppResources.Common.Limpiar)"
                            Click="FiltroLimpiar" />
                        </div>
                    </DxFormLayoutItem>

                </Items>
            </DxFormLayoutGroup>
        </DxFormLayout>

        <DxFormLayout>
            <DxFormLayoutGroup ColSpanSm="12" ColSpanMd="12" ColSpanLg="12" ColSpanXl="12" ColSpanXxl="12"
            Visible="true"
            ExpandButtonDisplayMode="GroupExpandButtonDisplayMode.Start"
            AnimationType="LayoutAnimationType.Slide">
                <CaptionTemplate>
                    <CaptionGroup LeftText="@LeftCaptionVigencias"
                    LeftBoldText=""
                    RightText="@RightCaptionVigencias" />
                </CaptionTemplate>
                <Items>
                    <DxFormLayoutItem ColSpanSm="6" ColSpanMd="6" ColSpanLg="3" ColSpanXl="3" ColSpanXxl="3" BeginRow="true"
                    CaptionPosition="CaptionPosition.Vertical" Context="formLayout">
                        <CaptionTemplate>
                            <span>@ObtenerTexto(AppResources.Pages.PlanificacionCondiciones.Vigencias)</span><span class="mandatory"></span>
                        </CaptionTemplate>
                        <Template>
                            <DxComboBox Data="@_vigencias"
                                        Enabled="!HayCambiosPendientes"
                                        Id="comboBoxVigencias"
                                        DropDownWidthMode="DropDownWidthMode.EditorWidth"
                                        TextFieldName=@nameof(Vigencia.Descripcion)
                                        ValueFieldName=@nameof(Vigencia.Codigo)
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        ListRenderMode="ListRenderMode.Entire"
                                        @bind-Value="@_vigenciaSeleccionada"
                                        SelectedDataItemChanged="(SelectedDataItemChangedEventArgs<Vigencia> args) =>
                                                                             ComboBoxVigencias_SelectedDataItemChanged(args)">
                                <EditBoxDisplayTemplate Context="contexto">
                                    @ListasTemplateHelper.GetComboBoxEditBoxTemplate(contexto.DataItem)
                                </EditBoxDisplayTemplate>
                            </DxComboBox>
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanSm="2" ColSpanMd="2" ColSpanLg="2" ColSpanXl="2" ColSpanXxl="2" BeginRow="false">
                        <div class="d-flex justify-content-start">
                            <DxButton CssClass="btnCustom"
                            Enabled="@(ValidarCamposObligatoriosFiltro() && !HayCambiosPendientes)"
                            Id="btnAńadirVigencia"
                            RenderStyle=ButtonRenderStyle.None
                            Text="@ObtenerTexto(AppResources.Botones.Anadir)"
                            IconCssClass="fa-solid fa-add"
                            Click="@AńadirVigencia" />
                        </div>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanSm="2" ColSpanMd="2" ColSpanLg="2" ColSpanXl="2" ColSpanXxl="2" BeginRow="false">
                        <div class="d-flex justify-content-start">
                            <DxButton CssClass="btnCustom"
                            Id="btnModificarVigencia"
                            Enabled="@(_vigenciaSeleccionada != null && !HayCambiosPendientes)"
                            RenderStyle=ButtonRenderStyle.None
                            Text="@ObtenerTexto(AppResources.Botones.Modificar)"
                            IconCssClass="fa-solid fa-edit"
                            Click="@EditarVigencia" />
                        </div>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanSm="2" ColSpanMd="2" ColSpanLg="2" ColSpanXl="2" ColSpanXxl="2" BeginRow="false">
                        <div class="d-flex justify-content-start">
                            <DxButton CssClass="btnCustom"
                            Id="btnEliminarVigencia"
                            Enabled="@(_vigenciaSeleccionada != null && !HayCambiosPendientes)"
                            RenderStyle=ButtonRenderStyle.None
                            Text="@ObtenerTexto(AppResources.Botones.Eliminar)"
                                      IconCssClass="fa-solid fa-trash"
                            Click="@EliminarVigencia" />
                        </div>
                    </DxFormLayoutItem>
                </Items>
            </DxFormLayoutGroup>



            @* POPUP EDIT VIGENCIAS *@
            <DxPopup Visible="@_popupVigenciaVisible"
            ShowFooter="true"
            HeaderText="@_tituloPopupVigencia"
            ShowCloseButton="false"
            Width="500px"
            Height="Auto"
            CloseOnEscape="false"
            CloseOnOutsideClick="false"
            AllowDrag="false"
            AllowDragByHeaderOnly="false">
                <BodyContentTemplate Context="popupContext">
                    <DxFormLayout>
                        <DxFormLayoutItem ColSpanSm="6" ColSpanMd="6" ColSpanLg="6" ColSpanXl="6" ColSpanXxl="6"
                        CaptionPosition="CaptionPosition.Vertical">
                            <CaptionTemplate>
                                <span>@ObtenerTexto(AppResources.Common.MesDesde)</span><span class="mandatory"></span>
                            </CaptionTemplate>
                            <Template>
                                <DxComboBox Data="@_meses"
                                            Id="comboBoxMesDesde"
                                            @bind-Value="@_mesDesdeVigenciaSeleccionado"
                                            ValueFieldName="@nameof(CodigoDescripcion.Codigo)"
                                            TextFieldName="@nameof(CodigoDescripcion.Descripcion)"
                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                            SearchMode="@ListSearchMode.AutoSearch"
                                            SearchFilterCondition="@ListSearchFilterCondition.Contains">
                                    <EditBoxDisplayTemplate Context="contexto">
                                        @ListasTemplateHelper.GetComboBoxEditBoxTemplate(contexto.DataItem)
                                    </EditBoxDisplayTemplate>

                                </DxComboBox>
                            </Template>
                        </DxFormLayoutItem>

                        <DxFormLayoutItem ColSpanSm="6" ColSpanMd="6" ColSpanLg="6" ColSpanXl="6" ColSpanXxl="6"
                        CaptionPosition="CaptionPosition.Vertical">
                            <CaptionTemplate>
                                <span>@ObtenerTexto(AppResources.Common.MesHasta)</span><span class="mandatory"></span>
                            </CaptionTemplate>
                            <Template>
                                <DxComboBox Data="@_meses"
                                            Id="comboBoxMesHasta"
                                            @bind-Value="@_mesHastaVigenciaSeleccionado"
                                            ValueFieldName="@nameof(CodigoDescripcion.Codigo)"
                                            TextFieldName="@nameof(CodigoDescripcion.Descripcion)"
                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                            SearchMode="@ListSearchMode.AutoSearch"
                                            SearchFilterCondition="@ListSearchFilterCondition.Contains">
                                    <EditBoxDisplayTemplate Context="contexto">
                                        @ListasTemplateHelper.GetComboBoxEditBoxTemplate(contexto.DataItem)
                                    </EditBoxDisplayTemplate>
                                </DxComboBox>
                            </Template>
                        </DxFormLayoutItem>

                    </DxFormLayout>
                </BodyContentTemplate>
                <FooterContentTemplate>
                    <div class="popupFooter">
                        <DxButton CssClass="btnCustom"
                        RenderStyle=ButtonRenderStyle.None
                        Text="@ObtenerTexto(AppResources.Common.Save)"
                        IconCssClass="fa-solid fa-save"
                        Click="@GrabarVigencia" />

                        <DxButton CssClass="btnCustom"
                        RenderStyle=ButtonRenderStyle.None
                        Text="@ObtenerTexto(AppResources.Botones.Cancelar)"

                        IconCssClass="fa-solid fa-cancel"
                        Click="@OcultarPopupVigencia" />
                    </div>
                </FooterContentTemplate>
            </DxPopup>

        </DxFormLayout>


        @* GRID CONDICIONES *@
        <DxFormLayout>
            <DxFormLayoutGroup ColSpanSm="12" ColSpanMd="12" ColSpanLg="12" ColSpanXl="12" ColSpanXxl="12"
            Visible="@(_vigenciaSeleccionada != null ?  true : false)"
            Caption="Condiciones"
            ExpandButtonDisplayMode="GroupExpandButtonDisplayMode.Start"
            AnimationType="LayoutAnimationType.Slide">
                <CaptionTemplate>
                    <CaptionGroup LeftText="@LeftCaptionCondiciones"
                    RightText="@RightCaptionCondiciones" />
                </CaptionTemplate>
                <Items>
                    <DxFormLayoutItem ColSpanSm="12" ColSpanMd="12" ColSpanLg="12" ColSpanXl="12" ColSpanXxl="12" Context="formLayout">
                        <DxGrid Data="@_condiciones"
                                @ref="GridCondiciones"
                        KeyFieldName="Key"
                        ValidationEnabled="false"
                        PagerVisible="false"
                        ShowFilterRow="false"
                        FocusedRowEnabled="false"
                        HighlightRowOnHover="true"
                        SelectionMode="GridSelectionMode.Single"
                        AllowSelectRowByClick="true"
                        CustomizeElement="GridCondiciones_CustomizeElement"
                        AllowColumnReorder="false"
                        AllowSort = "false"
                        EditMode="GridEditMode.EditCell">

                            <ToolbarTemplate>

                                <div class="d-flex justify-content-start">
                                    <DxButton CssClass="toolbarButtonCustom"
                                    RenderStyle=ButtonRenderStyle.None
                                    Text="@ObtenerTexto(AppResources.Botones.Cancelar)"
                                    Click="CancelarCambiosCondiciones"
                                    IconCssClass="fa-solid fa-cancel"
                                    Enabled="@(_condicionesNoGuardados.Count > 0)" />
                                </div>
                            </ToolbarTemplate>
                            <Columns>

                                <DxGridDataColumn FieldName="DescripcionMedio" 
                                Caption="@ObtenerTexto("Pages:PlanificacionCondiciones:Medio:label")" 
                                ReadOnly="true"
                                Width="35%"
                                CaptionAlignment="GridTextAlignment.Center"
                                DataRowEditorVisible="false"
                                TextAlignment="GridTextAlignment.Left">

                                    <CellDisplayTemplate>
                                        @{
                                            var dataItem = (CondicionDto)context.DataItem;
                                            string toolTip = dataItem.MedioAccesible ? "" : "Medio no accesible para el NetWork seleccinado";
                                        }
                                        <span class="dxgrid-readonly-cell" title="@toolTip">@context.DisplayText</span>
                                    </CellDisplayTemplate>


                                </DxGridDataColumn>

                                <DxGridDataColumn DisplayFormat="{0:N2} %" 
                                                  FieldName="@nameof(CondicionDto.PctSAG)" 
                                                  FilterRowEditorVisible="false"
                                                  Caption="@ObtenerTexto(AppResources.Pages.PlanificacionCondiciones.SagTpc)"
                                                  Width="10%"
                                                  CaptionAlignment="GridTextAlignment.Center"
                                                  TextAlignment="GridTextAlignment.Right" >

                                    <HeaderCaptionTemplate>
                                        <span title="@ObtenerTexto(AppResources.Pages.PlanificacionCondiciones.ToolTipSagTpc)">@ObtenerTexto(AppResources.Pages.PlanificacionCondiciones.SagTpc)</span>
                                    </HeaderCaptionTemplate>

                                    <CellDisplayTemplate>
                                        @if (context.DataItem is CondicionDto item)
                                        {
                                            string classCSSReadonly = "";
                                            if (!item.MedioAccesible)
                                            {
                                                classCSSReadonly = "dxgrid-readonly-cell";
                                            }
                                            if (item.PctSAG.HasValue)
                                            {
                                                string clase = "";
                                                if (HaCambiadoValorConceptoCondiciones(item, ConceptosCondiciones.Sag))
                                                {
                                                    clase = "grid-modified-cell";
                                                }
                                                <span class="@($"{clase} {classCSSReadonly}")">@context.DisplayText</span>
                                            }
                                            else
                                            {
                                                <span class="@($"{classCSSReadonly}")"></span>
                                            }
                                        }
                                    </CellDisplayTemplate>

                                    <CellEditTemplate>
                                        @{
                                            var editItem = ((CondicionDto)context.EditModel);
                                            var dataItem = ((CondicionDto)context.DataItem);
                                            bool soloLectura = !dataItem.MedioAccesible;
                                            <DxSpinEdit value="@editItem.PctSAG"
                                                        ShowSpinButtons="false"
                                                        CssClass="dxgrid-previsiones-cell"
                                                        MaxValue="100" 
                                                        MinValue="0"
                                                        ReadOnly="@soloLectura"
                                                        ValueChanged="@((decimal? v) => Condicion_SetPct(editItem,dataItem, ConceptosCondiciones.Sag, v))">
                                            </DxSpinEdit>
                                        }

                                    </CellEditTemplate>

                                </DxGridDataColumn>

                                <DxGridDataColumn DisplayFormat="{0:N2} %" 
                                                  FieldName="@nameof(CondicionDto.PctManPower)"
                                                  FilterRowEditorVisible="false"
                                                  Caption="@ObtenerTexto(AppResources.Pages.PlanificacionCondiciones.ManpowerTpc)"
                                                  Width="10%"
                                                  CaptionAlignment="GridTextAlignment.Center"
                                                  TextAlignment="GridTextAlignment.Right" >

                                    <HeaderCaptionTemplate>
                                        <span title="@ObtenerTexto(AppResources.Pages.PlanificacionCondiciones.ToolTipManpowerTpc)">@ObtenerTexto(AppResources.Pages.PlanificacionCondiciones.ManpowerTpc)</span>
                                    </HeaderCaptionTemplate>

                                    <CellDisplayTemplate>
                                        @if (context.DataItem is CondicionDto item)
                                        {
                                            string classCSSReadonly = "";
                                            if (!item.MedioAccesible)
                                            {
                                                classCSSReadonly = "dxgrid-readonly-cell";
                                            }
                                            if (item.PctManPower.HasValue)
                                            {
                                                string clase = "";
                                                if (HaCambiadoValorConceptoCondiciones(item, ConceptosCondiciones.Manpower))
                                                {
                                                    clase = "grid-modified-cell";
                                                }
                                                <span class="@($"{clase} {classCSSReadonly}")">@context.DisplayText</span>
                                            }
                                            else
                                            {
                                                <span class="@($"{classCSSReadonly}")"></span>
                                            }
                                        }
                                    </CellDisplayTemplate>

                                    <CellEditTemplate>
                                        @{
                                            var editItem = ((CondicionDto)context.EditModel);
                                            var dataItem = ((CondicionDto)context.DataItem);
                                            bool soloLectura = !dataItem.MedioAccesible;
                                            <DxSpinEdit value="@editItem.PctManPower"
                                                        ShowSpinButtons="false"
                                                        CssClass="dxgrid-previsiones-cell"
                                                        MaxValue="100" 
                                                        MinValue="0"
                                                        ReadOnly="@soloLectura"
                                                        ValueChanged="@((decimal? v) => Condicion_SetPct(editItem, dataItem, ConceptosCondiciones.Manpower, v))">
                                            </DxSpinEdit>
                                        }
                                    </CellEditTemplate>
                                </DxGridDataColumn>


                                <DxGridDataColumn FieldName="@nameof(CondicionDto.IndicadorCalculoDevolucion)"
                                                  FilterRowEditorVisible="false"
                                                  Caption="@ObtenerTexto(AppResources.Pages.PlanificacionCondiciones.BCDevolucion)"
                                                  Width="13%"
                                                  CaptionAlignment="GridTextAlignment.Center"
                                                  TextAlignment="GridTextAlignment.Left">
                                    <CellDisplayTemplate>

                                        @{
                                            var item = (CondicionDto)context.DataItem;
                                            string classCSSReadonly = "";
                                            if (!item.MedioAccesible)
                                            {
                                                classCSSReadonly = "dxgrid-readonly-cell";
                                            }
                                            var descripcion = _indicadoresDevolucion.FirstOrDefault(o => o.Codigo == item.IndicadorCalculoDevolucion)?.Descripcion ?? "";

                                            string clase = "";
                                            if (HaCambiadoValorConceptoCondiciones(item, ConceptosCondiciones.BaseCalculoDevolucion))
                                            {
                                                clase = "grid-modified-cell";
                                            }
                                        }
                                        <span class="@($"{clase} {classCSSReadonly}")">@descripcion</span>

                                    </CellDisplayTemplate>

                                    <CellEditTemplate>
                                        @{
                                            var editItem = (CondicionDto)context.EditModel;
                                            var dataItem = ((CondicionDto)context.DataItem);
                                            bool soloLectura = !dataItem.MedioAccesible;
                                            var css = editItem.IndicadorCalculoDevolucion != dataItem.IndicadorCalculoDevolucion ? "grid-modified-cell" : "";
                                        }
                                        <DxComboBox Data="@_indicadoresDevolucion"
                                                    TextFieldName=@nameof(CodigoDescripcion.Descripcion)
                                                    ValueFieldName=@nameof(CodigoDescripcion.Codigo)
                                                    Value="editItem.IndicadorCalculoDevolucion"
                                                    CssClass="@css"
                                                    ReadOnly="@soloLectura"
                                                    ValueChanged="@((int? v) => Condicion_SetDev(editItem,dataItem, v))"  />
                                    </CellEditTemplate>
                                </DxGridDataColumn>

                                <DxGridDataColumn FieldName="@nameof(CondicionDto.PctDevolucion)"
                                                  FilterRowEditorVisible="false"
                                                  Caption="@ObtenerTexto(AppResources.Pages.PlanificacionCondiciones.DevolucionTpc)"
                                                  Width="10%"
                                                  CaptionAlignment="GridTextAlignment.Center"
                                                  TextAlignment="GridTextAlignment.Right" DisplayFormat="{0:N2} %">

                                    <HeaderCaptionTemplate>
                                        <span title="@ObtenerTexto(AppResources.Pages.PlanificacionCondiciones.ToolTipDevolucionTpc)">@ObtenerTexto(AppResources.Pages.PlanificacionCondiciones.DevolucionTpc)</span>
                                    </HeaderCaptionTemplate>

                                    <CellDisplayTemplate>
                                        @if (context.DataItem is CondicionDto item)
                                        {
                                            string classCSSReadonly = "";
                                            if (!item.MedioAccesible)
                                            {
                                                classCSSReadonly = "dxgrid-readonly-cell";
                                            }
                                            if (item.PctDevolucion.HasValue)
                                            {
                                                string clase = "";
                                                if (HaCambiadoValorConceptoCondiciones(item, ConceptosCondiciones.Devolucion))
                                                {
                                                    clase = "grid-modified-cell";
                                                }
                                                <span class="@($"{clase} {classCSSReadonly}")">@context.DisplayText</span>
                                               
                                            }
                                            else
                                            {
                                                <span class="@($"{classCSSReadonly}")"></span>
                                            }
                                        }
                                    </CellDisplayTemplate>

                                    <CellEditTemplate>
                                        @{
                                            var editItem = ((CondicionDto)context.EditModel);
                                            var dataItem = ((CondicionDto)context.DataItem);
                                            bool soloLectura = !dataItem.MedioAccesible;
                                            <DxSpinEdit value="@editItem.PctDevolucion"
                                                        ShowSpinButtons="false"
                                                        CssClass="dxgrid-previsiones-cell"
                                                        MaxValue="100" 
                                                        MinValue="0"
                                                        ReadOnly="@soloLectura"
                                                        ValueChanged="@((decimal? v) => Condicion_SetPct(editItem,dataItem, ConceptosCondiciones.Devolucion, v))">
                                            </DxSpinEdit>
                                        }
                                    </CellEditTemplate>

                                </DxGridDataColumn>

