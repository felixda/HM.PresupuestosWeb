                                                    </i>
                                                }

                                                int max = _excepciones.Where(c => c.CodigoMedio == item.CodigoMedio).Max(c=> c.Jerarquia);
                                                if (item.Jerarquia < max)
                                                {
                                                    <i class="fas fa-arrow-down icono-accion"
                                                       title="Bajar"
                                                       @onclick="() => MoverJerarquia(item, AccionJerarquias.Bajar)">
