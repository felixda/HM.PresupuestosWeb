                                </DxGridDataColumn>

                                <DxGridDataColumn FieldName="@nameof(ExcepcionDto.CodigoObjetivo)"
                                                  FilterRowEditorVisible="false"
                                                  Caption="@ObtenerTexto(AppResources.Pages.PlanificacionCondiciones.Objetivo)"
                                                  Width="11%"
                                                  CaptionAlignment="GridTextAlignment.Center"
                                                  TextAlignment="GridTextAlignment.Left">

                                    <CellDisplayTemplate>
                                        @{
                                            var item = (ExcepcionDto)context.DataItem;
                                            //var descripcion = _objetivos.FirstOrDefault(o => o.Codigo == item.CodigoObjetivo)?.Descripcion ?? "";
                                            var descripcion = (item.ObjetivosDisponibles ?? _objetivos).FirstOrDefault(o => o.Codigo == item.CodigoObjetivo)?.Descripcion ?? "";
                                            string classCSSReadonly = "";
                                            if (!item.MedioAccesible)
                                            {
                                                classCSSReadonly = "dxgrid-readonly-cell";
                                            }
                                            string clase = "";
                                            if (HaCambiadoValorExcepciones(item, ConceptosCondicionesNMD.Objetivo))
                                            {
                                                clase = "grid-modified-cell";
                                            }
                                        }
                                        <span class="@($"{clase} {classCSSReadonly}")">@descripcion</span>
                                    </CellDisplayTemplate>
                                    <CellEditTemplate>
                                        @{
                                            var editItem = (ExcepcionDto)context.EditModel;
                                            var dataItem = ((ExcepcionDto)context.DataItem);
                                            bool soloLectura = !dataItem.MedioAccesible;
                                            var css = editItem.CodigoObjetivo != dataItem.CodigoObjetivo ? "grid-modified-cell" : "";
                                            var opcionesDisponibles = dataItem.ObjetivosDisponibles ?? _objetivos;
                                        }
                                        <DxComboBox Data="@opcionesDisponibles"
                                                    TextFieldName=@nameof(CodigoDescripcion.Descripcion)
                                                    ValueFieldName=@nameof(CodigoDescripcion.Codigo)
                                                    Value="editItem.CodigoObjetivo"
                                                    CssClass="@css"
                                                    ReadOnly="@soloLectura"
                                                    @onfocus="() => CargarConceptosNMD(dataItem, ConceptosCondicionesNMD.Objetivo)"
                                                    ValueChanged="@((int? v) => ExcepcionMedioCondicion_SetConceptosNMD(editItem,dataItem,ConceptosCondicionesNMD.Objetivo, v))" />
                                    </CellEditTemplate>
                                </DxGridDataColumn>

                                 <DxGridDataColumn FieldName="@nameof(ExcepcionDto.CodigoTipoCompra)"
                                                  FilterRowEditorVisible="false"
                                                  Caption="@ObtenerTexto(AppResources.Pages.PlanificacionCondiciones.TipoCompra)"
                                                  Width="11%"
                                                  CaptionAlignment="GridTextAlignment.Center"
                                                  TextAlignment="GridTextAlignment.Left">

                                    <CellDisplayTemplate>
                                        @{
                                            var item = (ExcepcionDto)context.DataItem;
                                            //var descripcion = _tiposCompra.FirstOrDefault(o => o.Codigo == item.CodigoTipoCompra)?.Descripcion ?? "";
                                            var descripcion = (item.TiposCompraDisponibles ?? _tiposCompra).FirstOrDefault(o => o.Codigo == item.CodigoTipoCompra)?.Descripcion ?? "";
                                            string classCSSReadonly = "";
                                            if (!item.MedioAccesible)
                                            {
                                                classCSSReadonly = "dxgrid-readonly-cell";
                                            }
                                            string clase = "";
                                            if (HaCambiadoValorExcepciones(item, ConceptosCondicionesNMD.TipoCompra))
                                            {
                                                clase = "grid-modified-cell";
                                            }
                                        }
                                        <span class="@($"{clase} {classCSSReadonly}")">@descripcion</span>

                                    </CellDisplayTemplate>
                                    <CellEditTemplate>
                                        @{
                                            var editItem = (ExcepcionDto)context.EditModel;
                                            var dataItem = ((ExcepcionDto)context.DataItem);
                                            bool soloLectura = !dataItem.MedioAccesible;
                                            var css = editItem.CodigoTipoCompra != dataItem.CodigoTipoCompra ? "grid-modified-cell" : "";
                                            var opcionesDisponibles = dataItem.TiposCompraDisponibles ?? _tiposCompra;
                                        }
                                        <DxComboBox Data="@opcionesDisponibles"
                                                    TextFieldName=@nameof(CodigoDescripcion.Descripcion)
                                                    ValueFieldName=@nameof(CodigoDescripcion.Codigo)
                                                    Value="editItem.CodigoTipoCompra"
                                                    CssClass="@css"
                                                    ReadOnly="@soloLectura"
                                                    @onfocus="() => CargarConceptosNMD(dataItem, ConceptosCondicionesNMD.TipoCompra)"
                                                    ValueChanged="@((int? v) => ExcepcionMedioCondicion_SetConceptosNMD(editItem,dataItem,ConceptosCondicionesNMD.TipoCompra, v))" />
                                    </CellEditTemplate>
                                </DxGridDataColumn>

                                <DxGridCommandColumn Width="5%" NewButtonVisible="false">
                                    <FilterRowCellTemplate>
                                    </FilterRowCellTemplate>
                                    <CellDisplayTemplate>
                                        <div class="grid-cell-align-center">
                                            <DxButton IconCssClass="fas fa-trash"
                                                      RenderStyle="ButtonRenderStyle.Link"
                                                      aria-label="Delete"
                                                      title="@ObtenerTexto(AppResources.Common.EliminarRegistro)"
                                                      Click="@(() => EliminarExcepcion(context.DataItem))" />
                                        </div>
                                    </CellDisplayTemplate>
                                    <CellEditTemplate>
                                        <div class="grid-cell-align-center">
                                            <DxButton Enabled="false"
                                                      aria-label="Delete"
                                                      CssClass="grid-disabled-button"
                                                      IconCssClass="fas fa-trash"
                                                      RenderStyle="ButtonRenderStyle.Link" />
                                        </div>
                                    </CellEditTemplate>
                                </DxGridCommandColumn>
                            </Columns>
                        </DxGrid>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem BeginRow="true"></DxFormLayoutItem>

                </ChildContent>
            </DxFormLayoutGroup>
        </DxFormLayout>


        @if (_vigenciaSeleccionada != null)
        {
            <DxFormLayout  >
                <DxFormLayoutItem ColSpanSm="4" ColSpanMd="3" ColSpanLg="2" ColSpanXl="2" ColSpanXxl="2" BeginRow="true">
                    <div class="d-flex justify-content-start">
                        <div class="d-flex justify-content-start">
                            <DxButton CssClass="btnCustom"
                                      RenderStyle=ButtonRenderStyle.None
                                      Text="@ObtenerTexto(AppResources.Common.Save)"
                                      Click="Grabar"
                                      IconCssClass="fa-solid fa-save"
                                      Enabled="@HayCambiosPendientes" />
                        </div>
                    </div>
                </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanSm="4" ColSpanMd="6" ColSpanLg="8" ColSpanXl="8" ColSpanXxl="8"> </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanSm="4" ColSpanMd="3" ColSpanLg="2" ColSpanXl="2" ColSpanXxl="2" BeginRow="false">
                    <div class="d-flex justify-content-end">
                        <DxButton CssClass="btnCustom"
                                  RenderStyle=ButtonRenderStyle.None
                                  Text="@ObtenerTexto(AppResources.Botones.Cancelar)"
                                  Click="CancelarCambios"
                                  IconCssClass="fa-solid fa-cancel"
                                  Enabled="@HayCambiosPendientes" />
                    </div>
                </DxFormLayoutItem>
             </DxFormLayout>
        }

        @* POPUP EDIT MEDIOS *@
        <DxPopup Visible="@_popupMediosVisible"
                 ShowFooter="true"
                 HeaderText="Selección de medios para nueva Excepción"
                 ShowCloseButton="false"
                 Width="500px"
                 Height="Auto"
                 CloseOnEscape="false"
                 CloseOnOutsideClick="false"
                 AllowDrag="false"
                 AllowDragByHeaderOnly="false">
            <BodyContentTemplate Context="popupContext">
                <DxFormLayout>
                    <DxFormLayoutItem ColSpanSm="6" ColSpanMd="6" ColSpanLg="6" ColSpanXl="6" ColSpanXxl="6"
                                      CaptionPosition="CaptionPosition.Vertical">
                        <CaptionTemplate>
                            <span>@ObtenerTexto(AppResources.Common.Medios)</span><span class="mandatory"></span>
                        </CaptionTemplate>
                        <Template>
                            <DxComboBox Data="@_mediosMaster"
                                        Id="comboBoxMedios"
                                        @bind-Value="@_medioSeleccionadoDesdePopup"
                                        ValueFieldName="@nameof(CodigoDescripcion.Codigo)"
                                        TextFieldName="@nameof(CodigoDescripcion.Descripcion)"
                                        SearchMode="@ListSearchMode.AutoSearch"
                                        SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto">
                                <EditBoxDisplayTemplate Context="contexto">
                                    @ListasTemplateHelper.GetComboBoxEditBoxTemplate(contexto.DataItem)
                                </EditBoxDisplayTemplate>
                            </DxComboBox>
                        </Template>
                    </DxFormLayoutItem>
                </DxFormLayout>
            </BodyContentTemplate>
            <FooterContentTemplate>
                <div class="popupFooter">
                    <DxButton CssClass="btnCustom"
                              RenderStyle=ButtonRenderStyle.None
                              Text="@ObtenerTexto(AppResources.Common.Aceptar)"
                              IconCssClass="fa-solid fa-save"
                              Enabled="@(_medioSeleccionadoDesdePopup != null)"
                              Click="@AńadirExcepcionDesdePopup" />

                    <DxButton CssClass="btnCustom"
                              RenderStyle=ButtonRenderStyle.None
                              Text="@ObtenerTexto(AppResources.Botones.Cancelar)"
                              IconCssClass="fa-solid fa-cancel"
                              Click="@OcultarPopupMedios" />
                </div>
            </FooterContentTemplate>
        </DxPopup>

    
    </div>

}



