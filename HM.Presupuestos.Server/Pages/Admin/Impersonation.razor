    /// <summary>
    /// Exceute impersonation
    /// </summary>
    private async Task LoginImpersonation(MouseEventArgs e)
    {
        try
        {
            _LayerOverlayService.Start();
            _message = "";
            _userNameImpersonation = (_userNameImpersonation!=null)?_userNameImpersonation.Replace(" ", ""):"";

            //Para las pruebas de seguridad en entornos distintos a PRO
            if (_Configuration.GetValue<string>("AppSettings:AppEnvironment") != Constantes.Environment.PRO)
            {
                if (e.CtrlKey && e.AltKey && (Usuario!.CodigoUsuario == 2825 || Usuario!.CodigoUsuario == 1182))
                {
                        _userNameImpersonation = "probar.acceso";
                        _passwordImpersonation = "ccc";
                }
            }

            if (!String.IsNullOrEmpty(_userNameImpersonation) && !String.IsNullOrEmpty(_passwordImpersonation))
            {
                if (_userAuthenticated.Login != _userNameImpersonation)
                {

                    var respuesta = await _UsuarioService.CargarUsuarioLoginDesdeServicioExterno(_userNameImpersonation, _passwordImpersonation);
                    if (respuesta)
                    {
                    _NavigationManager.NavigateTo("/home", forceLoad: false);
                    }
                    else
                    {
                        _message = T(AppResources.Pages.Impersonation.UsuarioNoAutorizado);
                    }

                }
                else
                {
                    _message = T(AppResources.Pages.Impersonation.UsuarioImpersonadoIgual);
                }
            }
            else
            {
                _message = T(AppResources.Pages.Impersonation.RellenarDatosUsuario);
            }
        }
        catch (Exception ex)
        {
            await LogService.InsertException(ex);
        }
        finally
        {
            _LayerOverlayService.Stop();
        }
    }


