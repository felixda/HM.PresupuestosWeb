    /// <summary>
    /// Storage user entity data
    /// </summary>
    /// <param name="user">UsuarioEntidad object</param>
    public async Task StorageUserProfile(UsuarioEntidad user)
    {
        await _SessionService.EstablecerUsuarioSesion(user);
    }



    /// <summary>
    /// Get user profile from internal security
    /// </summary>
    /// <param name="username">User name</param>
    /// <param name="jwt">IJwt object</param>
    /// <param name="securityController">IControlador object</param>
    /// <returns>True when success</returns>
    public async Task<UsuarioEntidad> GetUserProfile(string username, IJwt jwt, IControlador securityController)
    {
        var user = new UsuarioEntidad();
        try
        {
            if (string.IsNullOrEmpty(username)) { return user; }

            var userNameBasic = username.Substring(0, username.IndexOf("@"));
            var applicationCode = _Configuration.GetValue<int>("AppSettings:AppCode");
            var tokenInternalAuthentication = _Configuration.GetValue<string>("AppSettings:Session:TokenInternalAuthentication");
            RespuestaLogin respuestaLogin = await securityController.ValidarUsuario(applicationCode, userNameBasic, tokenInternalAuthentication);

            if (respuestaLogin.LoginStatus == LoginStatusEnum.Correcto)
            {
                user = jwt.ObtenerDatosUsuarioJwt(respuestaLogin.Jwt);

                List<Regla> reglas = new();

                foreach (ReglaEntidad reglaEntidad in respuestaLogin.Reglas)
                {
                    Regla regla = new();
                    regla.Id = reglaEntidad.Id;
                    regla.Descripcion = reglaEntidad.Descripcion;
                    regla.Password = reglaEntidad.Password;
                    reglas.Add(regla);
                }
                user.CodigoAplicacion = applicationCode;
                user.Reglas = reglas;
                user.Roles = respuestaLogin.Roles;
                user.Jwt = respuestaLogin.Jwt;
                user.Login = userNameBasic;

             
            }
        }
        catch (Exception ex)
        {
            await LogService.InsertException(ex);
        }
        return user;
    }

