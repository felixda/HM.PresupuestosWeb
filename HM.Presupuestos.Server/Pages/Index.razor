@page "/home"
@page "/index"

@using HM.Presupuestos.Server.Helper
@inherits Context

@if (!UsuarioCargado)
{
   @* Cargando... *@
}
else
{
    <PageTitle>@_pageTitle</PageTitle>

    <div class="welcome">
        <DxFormLayout CssClass="welcome-gridlayout">
            <ChildContent>
                <DxFormLayoutItem ColSpanSm="12" ColSpanMd="12" ColSpanLg="12" ColSpanXl="12" ColSpanXxl="12"
                    CssClass="welcome-title" Context="formLayout">
                    <Template>
                        <div class="welcome-title-header">
                            @($"{T(AppResources.Pages.Index.Hola)} {Usuario?.Nombre ?? ""}")
                        </div>
                        <div class="welcome-title-content">
                            @T(AppResources.Pages.Index.Bienvenida)
                        </div>
                    </Template>
                </DxFormLayoutItem>
                
                <DxFormLayoutItem ColSpanSm="12" ColSpanMd="12" ColSpanLg="12" ColSpanXl="12" ColSpanXxl="12" 
                    CssClass="welcome-cards" Context="formLayout">
                    <Template>
                        <DxFormLayout>
                            <ChildContent>
                                @foreach (var item in _menu.OrderBy(o => o.IndOrdenacion))
                                {
                                    <DxFormLayoutItem ColSpanSm="6" ColSpanMd="6" ColSpanLg="4" ColSpanXl="3" ColSpanXxl="3">
                                        <NavLink class="welcome-card" href="@T(AppResources.Menu.ObtenerUrl(item.Id))">
                                            <i class="@($"{T(AppResources.Menu.ObtenerIcono(item.Id))} fa-4x")" aria-hidden="true"></i>
                                            
                                            @{
                                                var menuParentName = item.IdPadre > 0 
                                                ? T(AppResources.Menu.ObtenerEtiqueta(item.IdPadre.Value))
                                                    : "";
                                            }
                                            <div class="welcome-card-title">@menuParentName</div>
                                            <div class="welcome-card-text">@T(AppResources.Menu.ObtenerEtiqueta(item.Id))</div>
                                        </NavLink>
                                    </DxFormLayoutItem>
                                }
                            </ChildContent>
                        </DxFormLayout>
                    </Template>
                </DxFormLayoutItem>
            </ChildContent>
        </DxFormLayout>
    </div>
}
