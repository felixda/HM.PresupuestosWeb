@using HM.Core.Comun.v6.Entidades.Configuracion
@using HM.Presupuestos.Server.Services
@using System.Globalization

@inject IResourceService _ResourceService
@inject NavigationManager _NavigationManager
@inject ICookieService CookieService
@inject ILogger<LanguageSwitcher> Logger
@inject IIdiomaService _IdiomaService

@inherits Context

@attribute [Authorize]

@if (!UsuarioCargado)
{
    @* <p>Comprobando permisos...</p> <!-- Se puede mostrar un loading si se quiere --> *@
}
else
{
    <div class="language-button-container">
        <DxButton CssClass="language-button" Text="@GetLanguageName(_currentLanguage)" Click="ToggleLanguageSwitcher" />
        @if (_showLanguageSwitcher)
        {
            <div class="language-switcher-drop shadow-sm" @onclick:stopPropagation>
                @foreach (var language in _ResourceService.ObtenerIdiomas())
                {
                    <div class="language-item @GetActiveClass(language.Iso)" @onclick="@(() => ChangeLanguage(language.Iso))">
                        <span class="language-label">@GetLanguageName(language.Iso)</span>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private const string LANGUAGE_COOKIE_KEY = "app_language";
    private const int LANGUAGE_COOKIE_EXPIRE_DAYS = 365;

    private bool _showLanguageSwitcher = false;


    private List<string>? _languageCodeList = new List<string>();
    private string _currentLanguage = "";

    private bool _initialized;


    protected override async Task OnUsuarioDisponibleAsync()
    {
        _languageCodeList = _ResourceService.ObtenerCodigosIdiomas();
        _currentLanguage = _IdiomaService.Idioma;

        SetAppCulture(_currentLanguage);

        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Set application culture for global and Devexpress
    /// </summary>
    /// <param name="culture">String culture code</param>
    private void SetAppCulture(string culture)
    {
        if (!String.IsNullOrEmpty(culture))
        {
            var obCultureInfo = new CultureInfo(culture);
            CultureInfo.DefaultThreadCurrentCulture = obCultureInfo;
            CultureInfo.DefaultThreadCurrentUICulture = obCultureInfo;
        }
    }

   
