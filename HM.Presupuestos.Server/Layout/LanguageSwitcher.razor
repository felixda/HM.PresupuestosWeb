    private void ToggleLanguageSwitcher()
    {
        _showLanguageSwitcher = !_showLanguageSwitcher;
    }

    private async Task ChangeLanguage(string iso)
    {
        try
        {
            Logger.LogInformation("🌐 Cambiando idioma a: {Language}", iso);

            // Convertir código ISO corto a formato completo
            // string fullLanguageCode = ConvertirIsoACodigoCompleto(iso);
            // Logger.LogDebug("🔧 Código idioma completo: {Code}", fullLanguageCode);

            await _IdiomaService.CambiarIdioma(iso);

            // // Verificar que se guardó correctamente
            // var verificacion = CookieService.GetCookie(LANGUAGE_COOKIE_KEY);
            // Logger.LogInformation("✅ Cookie verificada: {Value}", verificacion);

            _currentLanguage = iso;
            _showLanguageSwitcher = false;

            await InvokeAsync(StateHasChanged);

            // Recargar con la nueva cookie
            //
            // -    *ººººº-------------------º_NavigationManager.NavigateTo(_NavigationManager.Uri, forceLoad: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "❌ Error al cambiar idioma");
        }
    }

    /// <summary>
    /// Convertir código ISO corto (es, en, pt) a formato completo (es-ES, en-US, pt-PT)
    /// </summary>
    private string ConvertirIsoACodigoCompleto(string iso)
    {
        return iso.ToLower() switch
        {
            "es" => "es-ES",
            "en" => "en-US",
            "pt" => "pt-PT",
            "fr" => "fr-FR",
            _ => "es-ES" // Por defecto español
        };
    }

    private string GetLanguageName(string iso)
    {
        return T($"Language:{iso}:label");
    }

    private string GetActiveClass(string iso)
    {
        return iso == _currentLanguage ? "active" : "";
    }
}
